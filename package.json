{
  "name": "plvs",
  "description": "PLVS — real-time audio metering desktop app (Peak / Loudness / Vectorscope / Spectrum)",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "prepare": "simple-git-hooks",
    "theme:generate": "node scripts/generate-theme-fallbacks.mjs",
    "prebuild": "npm run theme:generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\"",
    "lint": "eslint src",
    "version:check": "node scripts/verify-versions.mjs",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:check": "npm run rust:fmt && npm run rust:clippy && npm run rust:test",
    "check": "npm run version:check && npm run format:check && npm run lint && npm test && npm run build && npm run rust:check",
    "tauri": "tauri",
    "desktop": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:release-nsis": "tauri build --bundles nsis",
    "desktop:release-dmg": "tauri build --bundles dmg"
  },
  "simple-git-hooks": {
    "pre-commit": "cargo fmt --manifest-path src-tauri/Cargo.toml --all && npx lint-staged && { git diff --cached --name-only | grep -q src-tauri/Cargo.toml && (cd src-tauri && cargo generate-lockfile && git add Cargo.lock) || true; }"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,css,json}": "prettier --write"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.0",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.11",
    "vitest": "^4.1.4"
  }
}

{
  "name": "audiometer-modern-ui",
  "description": "Browser-based real-time audio meter — loudness (LUFS), peak, spectrum, and vectorscope",
  "private": true,
  "version": "0.0.10",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "version:check": "node scripts/verify-versions.mjs",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:check": "npm run rust:fmt && npm run rust:clippy && npm run rust:test",
    "check": "npm run version:check && npm run lint && npm test && npm run build && npm run rust:check",
    "tauri": "tauri",
    "desktop": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:release-nsis": "tauri build --bundles nsis",
    "desktop:release-dmg": "tauri build --bundles dmg"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.4",
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.0",
    "tailwindcss": "^4.1.4",
    "vite": "^7.0.0",
    "vitest": "^4.1.4"
  }
}
